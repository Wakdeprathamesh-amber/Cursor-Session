<%- include("../partials/header", { title: "Your Cart" }) %>

<section class="card">
  <h1>Your Cart</h1>
  <% if (items.length === 0) { %>
    <p>Your cart is empty.</p>
    <a href="/" class="btn">Browse products</a>
  <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Qty</th>
          <th>Price</th>
          <th>Subtotal</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach((item) => { %>
          <tr>
            <td><%= item.name %></td>
            <td>
              <form method="post" action="/cart/update" class="inline-form">
                <input type="hidden" name="cart_item_id" value="<%= item.cart_item_id %>" />
                <input type="number" min="1" name="quantity" value="<%= item.quantity %>" />
                <button type="submit" class="link-button">Update</button>
              </form>
            </td>
            <td>$<%= item.price.toFixed(2) %></td>
            <td>$<%= (item.price * item.quantity).toFixed(2) %></td>
            <td>
              <form method="post" action="/cart/remove">
                <input type="hidden" name="cart_item_id" value="<%= item.cart_item_id %>" />
                <button type="submit" class="link-button danger">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <div class="cart-total">
      <span>Total</span>
      <strong>$<%= total.toFixed(2) %></strong>
    </div>
    <form method="post" action="/checkout">
      <button class="btn" type="submit">Place Order</button>
    </form>
  <% } %>
</section>

<%- include("../partials/footer") %>
